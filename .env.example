# Production environment template.
# Copy this file to .env locally, but set real production values in your host's
# secret/env manager. Never commit .env files.

# Required: Postgres connection string used by Prisma.
# For Neon/Supabase/managed Postgres, keep SSL enabled.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Required for signing NextAuth session tokens.
# Use at least 32 random bytes. Example generator:
# openssl rand -base64 48
NEXTAUTH_SECRET="replace-with-a-long-random-production-secret"

# Required in production: canonical app origin for redirects, links, and callbacks.
NEXTAUTH_URL="https://your-production-domain.com"
